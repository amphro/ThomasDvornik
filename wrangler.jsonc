{
  "$schema": "./node_modules/wrangler/config-schema.json",
  "name": "thomasdvornik",
  "main": "dist/_worker.js/index.js",
  "compatibility_date": "2026-06-19",
  "compatibility_flags": ["nodejs_compat"],
  "assets": {
    "directory": "dist",
    "binding": "ASSETS"
  },
  "ai": {
    "binding": "AI"
  },
  "kv_namespaces": [
    {
      "binding": "RATE_LIMIT",
      "id": "6632e86ec9fc45e5986e7a34378c3943"
    }
  ]
}
