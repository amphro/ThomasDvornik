---
import social from '../../data/social.json';
---

<footer class="footer">
  <div class="footer-inner">
    <span class="copy">© {new Date().getFullYear()} Thomas Dvornik</span>
    <div class="links">
      {
        social.map(({ shortname, url }) => (
          <a
            href={url}
            target="_blank"
            rel="noopener noreferrer"
            class="link"
          >
            {shortname}
          </a>
        ))
      }
    </div>
  </div>
</footer>

<style>
  .footer {
    border-top: 1px solid var(--border);
    padding: 2rem max(1.5rem, 4vw);
    margin-top: 6rem;
  }

  .footer-inner {
    max-width: 1100px;
    margin: 0 auto;
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  .copy {
    font-size: 0.8rem;
    color: var(--muted);
    font-family: var(--font-mono);
  }

  .links {
    display: flex;
    gap: 1.5rem;
  }

  .link {
    font-size: 0.8rem;
    color: var(--muted);
    text-decoration: none;
    text-transform: capitalize;
    letter-spacing: 0.05em;
    transition: color 0.15s ease;
  }

  .link:hover {
    color: var(--accent);
  }
</style>
