---
import BaseLayout from '../../layouts/BaseLayout.astro';
export const prerender = true;

const articles = [
  {
    href: 'https://amphro.github.io/ai-optimizations/',
    title: 'What Is AI, Actually?',
    tag: 'AI · Fundamentals',
    description:
      'A plain-English breakdown of how AI systems work, written for people who build with the technology rather than just talk about it.',
    external: true,
  },
];
---

<BaseLayout
  title="Writing"
  description="Notes on AI, platforms, and building by Thomas Dvornik."
>
  <div class="page">
    <div class="container">
      <header class="page-header">
        <span class="label">Writing</span>
        <h1>Notes on building.</h1>
        <p class="subtitle">
          AI, enterprise platforms, and the craft of shipping things that last.
        </p>
      </header>

      <div class="article-list">
        {
          articles.map(article => (
            <a
              href={article.href}
              class="article-card"
              target={article.external ? '_blank' : undefined}
              rel={article.external ? 'noopener noreferrer' : undefined}
            >
              <div class="article-meta">
                <span class="article-tag">{article.tag}</span>
                {article.external && <span class="external-badge">External ↗</span>}
              </div>
              <h2>{article.title}</h2>
              <p>{article.description}</p>
            </a>
          ))
        }
      </div>
    </div>
  </div>
</BaseLayout>

<style>
  .page {
    padding: 8rem max(1.5rem, 4vw) 4rem;
  }

  .container {
    max-width: 720px;
    margin: 0 auto;
  }

  .page-header {
    margin-bottom: 3rem;
  }

  .label {
    font-size: 0.7rem;
    text-transform: uppercase;
    letter-spacing: 0.14em;
    color: var(--accent);
    font-family: var(--font-mono);
  }

  h1 {
    font-size: clamp(2.25rem, 5vw, 3.5rem);
    font-weight: 800;
    letter-spacing: -0.025em;
    color: var(--text);
    margin: 0.4rem 0 1rem;
  }

  .subtitle {
    font-size: 1.05rem;
    color: var(--muted);
    line-height: 1.65;
    max-width: 560px;
    margin: 0;
  }

  .article-list {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .article-card {
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
    padding: 1.75rem;
    border: 1px solid var(--border);
    border-radius: 8px;
    background: var(--surface);
    text-decoration: none;
    color: inherit;
    transition: border-color 0.2s ease, box-shadow 0.2s ease;
  }

  .article-card:hover {
    border-color: var(--accent);
    box-shadow: var(--shadow-md);
  }

  .article-meta {
    display: flex;
    align-items: center;
    gap: 0.75rem;
  }

  .article-tag {
    font-size: 0.7rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--accent);
    font-family: var(--font-mono);
  }

  .external-badge {
    font-size: 0.65rem;
    color: var(--muted);
    font-family: var(--font-mono);
    letter-spacing: 0.05em;
  }

  .article-card h2 {
    font-size: 1.2rem;
    font-weight: 700;
    color: var(--text);
    letter-spacing: -0.01em;
    margin: 0;
  }

  .article-card p {
    font-size: 0.9rem;
    color: var(--muted);
    line-height: 1.65;
    margin: 0;
  }
</style>
