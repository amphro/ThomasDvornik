---
import BaseLayout from '../../layouts/BaseLayout.astro';
export const prerender = true;

const demos = [
  {
    href: '/ai-labs/vibe-check',
    title: 'Vibe Check',
    tag: 'AI · Language',
    description:
      'Paste in corporate jargon (meeting recap, email, Slack message) and get the plain-English translation, what\'s really being said between the lines, and a suggested reply.',
    status: 'Live',
  },
  {
    href: '/ai-labs/steelman',
    title: 'Steelman Machine',
    tag: 'AI · Strategy',
    description:
      'Drop in a position or decision. Get the strongest possible counterargument, its actual weaknesses, and a score for how defensible your position is.',
    status: 'Live',
  },
];
---

<BaseLayout
  title="AI Labs"
  description="Live AI experiments and demos by Thomas Dvornik."
>
  <div class="page">
    <div class="container">
      <header class="page-header">
        <span class="label">AI Labs</span>
        <h1>AI in the wild.</h1>
        <p class="subtitle">
          Live experiments. Not mockups, not screenshots. Things that run in
          the browser right now, wired to real models on Cloudflare's edge.
        </p>
      </header>

      <div class="demo-grid">
        {
          demos.map(demo => (
            <a href={demo.href} class="demo-card">
              <div class="demo-meta">
                <span class="demo-tag">{demo.tag}</span>
                <span class="demo-live">Live</span>
              </div>
              <h2>{demo.title}</h2>
              <p>{demo.description}</p>
              <span class="demo-link">Open demo →</span>
            </a>
          ))
        }
      </div>
    </div>
  </div>
</BaseLayout>

<style>
  .page {
    padding: 8rem max(1.5rem, 4vw) 4rem;
  }

  .container {
    max-width: 900px;
    margin: 0 auto;
  }

  .page-header {
    margin-bottom: 4rem;
  }

  .label {
    font-size: 0.7rem;
    text-transform: uppercase;
    letter-spacing: 0.14em;
    color: var(--accent);
    font-family: var(--font-mono);
  }

  h1 {
    font-size: clamp(2.25rem, 5vw, 3.5rem);
    font-weight: 800;
    letter-spacing: -0.025em;
    color: var(--text);
    margin: 0.4rem 0 1rem;
  }

  .subtitle {
    font-size: 1.05rem;
    color: var(--muted);
    line-height: 1.65;
    max-width: 560px;
    margin: 0;
  }

  .demo-grid {
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
  }

  .demo-card {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    padding: 2rem;
    border: 1px solid color-mix(in srgb, var(--accent) 25%, var(--border));
    border-radius: 8px;
    background: var(--surface);
    text-decoration: none;
    color: inherit;
    transition: border-color 0.2s ease, box-shadow 0.2s ease, transform 0.15s ease;
  }

  .demo-card:hover {
    border-color: var(--accent);
    box-shadow: var(--shadow-md);
    transform: translateY(-2px);
  }

  .demo-meta {
    display: flex;
    align-items: center;
    gap: 0.75rem;
  }

  .demo-tag {
    font-size: 0.7rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--accent);
    font-family: var(--font-mono);
  }

  .demo-live {
    font-size: 0.65rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: #4ade80;
    font-family: var(--font-mono);
    padding: 0.15rem 0.55rem;
    border-radius: 999px;
    border: 1px solid rgba(74, 222, 128, 0.3);
    background: rgba(74, 222, 128, 0.08);
  }

  .demo-card h2 {
    font-size: 1.25rem;
    font-weight: 700;
    color: var(--text);
    letter-spacing: -0.01em;
    margin: 0;
  }

  .demo-card p {
    font-size: 0.9rem;
    color: var(--muted);
    line-height: 1.65;
    margin: 0;
  }

  .demo-link {
    margin-top: 0.5rem;
    font-size: 0.875rem;
    color: var(--accent);
    font-weight: 500;
  }
</style>
