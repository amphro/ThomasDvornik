---
import BaseLayout from '../../layouts/BaseLayout.astro';
export const prerender = true;

const roles = [
  {
    company: 'Salesforce',
    title: 'Principal Member of Technical Staff',
    period: 'Apr 2016 – Present',
    location: 'San Francisco, CA',
    chapters: [
      {
        name: 'Digital Wallet: Consumption Metering and Billing Infrastructure',
        period: '2023 – Present',
        highlights: [
          'Architected the billing-authoritative Tenant Directory: source-of-truth registry for consumption metering across enterprise customers with 100+ production orgs, designed independently from identity and trust directories to preserve billing accuracy.',
          'Consumption metering pipeline: event-publishing libraries across product teams, Kafka event bus, Spark-based aggregation through Data Cloud connectors, downstream routing to billing and analytics surfaces.',
          'Designed Global Consumption View (October 2026 pilot): multi-org metering aggregation for the company\'s largest enterprises. Set MVP scope and drove alignment across a 21-person architecture workgroup.',
          'Led Custom Tagging from design to GA: customer-defined cost allocation on Agentforce credits, Data Cloud usage, and all metered resources. Shipped across 3 release branches simultaneously. Led incident bridge response to a customer-impacting severity incident at GA, resolving impact for enterprise accounts.',
          'Co-architected Agentic Experience for Sellers in Java and TypeScript: text-to-SQL agent over multi-tenant consumption data; SQL generation, validation, and sanitization covering injection hardening and hallucination defense; prompt versioning with immutable folder-per-version, feature gate, and QA override.',
          'Co-developed the Digital Wallet developer playground: shared hosted Java app fully adopted by DW and Onboarding teams for test-org setup, planning, feature verification, pipeline debugging, and team onboarding.',
          'Designed multi-day end-to-end tests spanning the pipeline\'s async aggregation and settlement windows, detecting upstream data regressions before they reach billing.',
          'AI Champion for the org (~50 engineers across Digital Wallet and GTM): agentic workflow adoption, Refactor Fridays, first Claude Code beta access (August 2025), cross-team PRs via agentic workflows.',
        ],
        tags: ['Java', 'TypeScript', 'Kafka', 'Spark', 'Data Cloud', 'AI Agents', 'SQL'],
      },
      {
        name: 'Salesforce DX / CLI & Developer Platform',
        period: '2016 – 2022',
        highlights: [
          'Architected the Salesforce CLI from conception to 30M+ monthly executions: 130+ commands, 60+ external plugins, 4,000+ automated tests across OS and shell matrix. Led CLI Unification (sfdx → sf), consolidating Salesforce\'s fragmented developer tools into one canonical CLI for the external ecosystem.',
          'Designed the CLI plugin architecture: signed and unsigned plugin trust model, install and update lifecycle, telemetry surface, and release infrastructure that scaled safely to 60+ community plugins.',
          'Trusted committer on oclif open-source CLI framework: 27 PRs covering ESM loading, help customization, docopts, and postpack install hook.',
          '66 PRs into sfdx-core (auth flows, crypto-in-config, org management); 188 PRs into salesforcecli plugin ecosystem.',
          'Co-led Salesforce Extensions for Visual Studio Code (Apex IntelliSense, deploy/retrieve, SOQL builder) across 7 release trains.',
        ],
        tags: ['TypeScript', 'Node.js', 'CLI', 'OSS', 'oclif', 'VS Code'],
      },
      {
        name: 'Sales Cloud: Einstein Conversation Insights',
        period: '2022 – 2023',
        highlights: [
          'Shipped Call Summary: LLM-powered post-call summaries for sellers. First production LLM feature. Owned prompt design, output validation, hallucination handling, and customer opt-in.',
        ],
        tags: ['LLM', 'Java', 'Prompt Engineering'],
      },
      {
        name: 'Trailhead: My Trailhead Integration',
        period: '2021 – 2022',
        highlights: [
          'Integrated My Trailhead (enterprise-branded learning) into the core Salesforce platform; shipped enablement UI framework and in-product guided learning paths.',
        ],
        tags: ['Full-stack', 'Platform'],
      },
    ],
    tags: ['TypeScript', 'Java', 'CLI', 'AI', 'Platform', 'OSS'],
  },
  {
    company: 'HearNow Technologies',
    title: 'Co-Founder & CTO',
    period: 'Sep 2015 – Apr 2016',
    location: 'San Francisco, CA',
    chapters: [
      {
        name: null,
        period: null,
        highlights: [
          'Built IoT notification platform from scratch: Node.js, Express, MongoDB, Twilio, AWS.',
          'Investor demos, device-to-service firmware integration, full IT operations.',
        ],
        tags: ['Node.js', 'AWS', 'IoT', 'Startup'],
      },
    ],
    tags: ['Node.js', 'AWS', 'IoT'],
  },
  {
    company: 'Salesforce',
    title: 'Intern → Associate MTS → Lead MTS',
    period: 'Sep 2008 – Sep 2015',
    location: 'San Francisco, CA',
    chapters: [
      {
        name: 'Platform UI',
        period: '2011 – 2015',
        highlights: [
          'Built the Developer Console: Salesforce\'s in-browser Apex/SOQL/debug IDE, still in wide production use 15 years later.',
          'Built the Setup tree: hierarchical admin navigation in Salesforce Setup, and by interaction count the most-used single component in the entire Setup experience.',
          'Won two internal hack days. Created Dreamforce prototypes and demos.',
        ],
        tags: ['JavaScript', 'Java', 'CodeMirror', 'UI'],
      },
    ],
    tags: ['JavaScript', 'Java', 'UI'],
  },
];

const talks = [
  {
    event: 'Dreamforce 2019',
    session: 'How an Architect thinks about Salesforce DX',
    detail: '2 sessions · 262 attendees · 1,295 bookmarks · 4.35–4.71 ratings',
  },
  {
    event: 'oclifconf 2019',
    session: 'Building an Enterprise CLI with Salesforce and oclif',
    detail: '25-min talk · Terra Gallery, San Francisco',
  },
  {
    event: 'TrailheaDX 2019',
    session: 'The Salesforce DX Cheatsheet',
    detail: 'San Francisco · Moscone',
  },
  {
    event: 'TrailheaDX 2017',
    session: 'Build and Customize Your Tools Using the Salesforce DX CLI',
    detail: '40-min session · stepped in on short notice',
  },
];
---

<BaseLayout title="Work" description="Career, projects, and platforms by Thomas Dvornik.">
  <div class="page">
    <div class="container">
      <header class="page-header">
        <span class="label">Work</span>
        <h1>Enterprise at scale.</h1>
        <p class="subtitle">
          Over 15 years at Salesforce and one startup, I've built platform UI,
          developer tooling, LLM products, billing infrastructure, and agentic AI.
        </p>
      </header>

      <section class="experience">
        <h2 class="section-label">Experience</h2>
        <div class="roles">
          {roles.map(role => (
            <div class="role-card">
              <div class="role-header">
                <div>
                  <div class="role-company">{role.company}</div>
                  <div class="role-title">{role.title}</div>
                </div>
                <div class="role-right">
                  <div class="role-period">{role.period}</div>
                  <div class="role-location">{role.location}</div>
                </div>
              </div>
              <div class="chapters">
                {role.chapters.map(ch => (
                  <div class="chapter">
                    {ch.name && (
                      <div class="chapter-header">
                        <span class="chapter-name">{ch.name}</span>
                        {ch.period && <span class="chapter-period">{ch.period}</span>}
                      </div>
                    )}
                    <ul class="highlights">
                      {ch.highlights.map(h => (
                        <li>{h}</li>
                      ))}
                    </ul>
                    <div class="tags">
                      {ch.tags.map(t => <span class="tag">{t}</span>)}
                    </div>
                  </div>
                ))}
              </div>
            </div>
          ))}
        </div>
      </section>

      <section class="speaking">
        <h2 class="section-label">Speaking</h2>
        <div class="talks">
          {talks.map(talk => (
            <div class="talk-row">
              <div class="talk-event">{talk.event}</div>
              <div class="talk-right">
                <div class="talk-session">{talk.session}</div>
                <div class="talk-detail">{talk.detail}</div>
              </div>
            </div>
          ))}
        </div>
      </section>

      <section class="education">
        <h2 class="section-label">Education & Research</h2>
        <div class="edu-card">
          <div class="edu-school">California Polytechnic State University, San Luis Obispo</div>
          <div class="edu-degrees">
            MS Computer Science &nbsp;·&nbsp; BS Computer Science &nbsp;·&nbsp; 2010–2011
          </div>
          <div class="edu-thesis">
            Thesis: <a
              href="https://ieeexplore.ieee.org/document/5876137"
              target="_blank"
              rel="noopener noreferrer"
              class="inline-link"
            >Supporting Introductory Test-Driven Labs with WebIDE</a>, published in IEEE Xplore
          </div>
        </div>
      </section>

    </div>
  </div>
</BaseLayout>

<style>
  .page {
    padding: 8rem max(1.5rem, 4vw) 6rem;
  }

  .container {
    max-width: 900px;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    gap: 4.5rem;
  }

  .page-header {
    display: flex;
    flex-direction: column;
    gap: 0;
  }

  .label,
  .section-label {
    font-size: 0.7rem;
    text-transform: uppercase;
    letter-spacing: 0.14em;
    color: var(--accent);
    font-family: var(--font-mono);
    font-weight: 500;
    margin: 0 0 1.25rem;
  }

  h1 {
    font-size: clamp(2.25rem, 5vw, 3.5rem);
    font-weight: 800;
    letter-spacing: -0.025em;
    color: var(--text);
    margin: 0.4rem 0 1rem;
  }

  .subtitle {
    font-size: 1.05rem;
    color: var(--muted);
    line-height: 1.65;
    max-width: 580px;
    margin: 0;
  }

  /* ── Roles ── */
  .roles {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  .role-card {
    padding: 2rem;
    border: 1px solid var(--border);
    border-radius: 10px;
    background: var(--surface);
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  .role-header {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 1rem;
    flex-wrap: wrap;
    padding-bottom: 1.25rem;
    border-bottom: 1px solid var(--border);
  }

  .role-company {
    font-size: 1rem;
    font-weight: 700;
    color: var(--text);
  }

  .role-title {
    font-size: 0.875rem;
    color: var(--muted);
    margin-top: 0.2rem;
  }

  .role-right {
    text-align: right;
    flex-shrink: 0;
  }

  .role-period {
    font-size: 0.8rem;
    font-family: var(--font-mono);
    color: var(--accent);
  }

  .role-location {
    font-size: 0.8rem;
    color: var(--muted);
    margin-top: 0.15rem;
  }

  .chapters {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  .chapter {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .chapter-header {
    display: flex;
    align-items: baseline;
    gap: 0.75rem;
    flex-wrap: wrap;
  }

  .chapter-name {
    font-size: 0.875rem;
    font-weight: 600;
    color: var(--text);
  }

  .chapter-period {
    font-size: 0.72rem;
    color: var(--muted);
    font-family: var(--font-mono);
  }

  .highlights {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
  }

  .highlights li {
    font-size: 0.875rem;
    color: var(--muted);
    line-height: 1.65;
    padding-left: 1.25rem;
    position: relative;
  }

  .highlights li::before {
    content: '—';
    position: absolute;
    left: 0;
    color: var(--accent);
  }

  .tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
  }

  .tag {
    font-size: 0.65rem;
    font-family: var(--font-mono);
    color: var(--muted);
    letter-spacing: 0.08em;
    padding: 0.15rem 0.55rem;
    border-radius: 999px;
    border: 1px solid var(--border);
  }

  /* ── Speaking ── */
  .talks {
    display: flex;
    flex-direction: column;
    gap: 0;
    border: 1px solid var(--border);
    border-radius: 10px;
    overflow: hidden;
  }

  .talk-row {
    display: flex;
    align-items: flex-start;
    gap: 1.5rem;
    padding: 1.25rem 1.5rem;
    background: var(--surface);
    border-bottom: 1px solid var(--border);
  }

  .talk-row:last-child {
    border-bottom: none;
  }

  .talk-event {
    font-size: 0.8rem;
    font-family: var(--font-mono);
    color: var(--accent);
    white-space: nowrap;
    flex-shrink: 0;
    min-width: 140px;
    padding-top: 0.1rem;
  }

  .talk-session {
    font-size: 0.9rem;
    color: var(--text);
    font-weight: 500;
  }

  .talk-detail {
    font-size: 0.8rem;
    color: var(--muted);
    margin-top: 0.2rem;
  }

  /* ── Education ── */
  .edu-card {
    padding: 1.75rem 2rem;
    border: 1px solid var(--border);
    border-radius: 10px;
    background: var(--surface);
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .edu-school {
    font-size: 1rem;
    font-weight: 600;
    color: var(--text);
  }

  .edu-degrees {
    font-size: 0.875rem;
    color: var(--muted);
    font-family: var(--font-mono);
  }

  .edu-thesis {
    font-size: 0.875rem;
    color: var(--muted);
    line-height: 1.6;
    margin-top: 0.25rem;
  }

  .inline-link {
    color: var(--accent);
    text-decoration: none;
    border-bottom: 1px solid color-mix(in srgb, var(--accent) 40%, transparent);
    transition: border-color 0.15s ease;
  }

  .inline-link:hover {
    border-color: var(--accent);
  }
</style>
